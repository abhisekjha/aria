# Claude API (Anthropic)
ANTHROPIC_API_KEY=

# Apollo.io (prospecting — free tier)
APOLLO_API_KEY=

# Gmail (sending via SMTP + reading via API)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=        # 16-char app password from Google account settings
GMAIL_OAUTH_CREDENTIALS=   # JSON string — from Google Cloud Console OAuth2

# Airtable (CRM)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Approval system
APPROVAL_SECRET=           # random 32-char string — run: python -c "import secrets; print(secrets.token_hex(16))"
RAILWAY_WEBHOOK_URL=       # e.g. https://aria-webhook.up.railway.app

# Human contact
HUMAN_EMAIL=               # your personal email — where all alerts go
CAL_COM_LINK=              # e.g. https://cal.com/yourname/auralix-demo

# Cal.com webhooks
CAL_COM_WEBHOOK_SECRET=    # from Cal.com → Settings → Webhooks

# Safety controls
DRY_RUN=true               # set false only when ready to send real emails
MAX_PROSPECTS_PER_DAY=10   # hard limit — never exceed Apollo free tier
